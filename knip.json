{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": ["src/**/*.ts"],
  "ignore": [
    "src/scripts/*"
  ],
  "ignoreBinaries": [
    "scripts/dev-normalization.sh"
  ],
  "rules": {
    "exports": "error",
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "types": "warn"
  }
}
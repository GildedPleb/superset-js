GITHUB_TOKEN=ghp_your_token_here

MINIO_ACCESS_KEY=key
MINIO_SECRET_KEY=secret

# === Feature flags (new in K8s spike) ===
# Coarse toggle
ENABLE_INGESTION=true

# Granular normalization pathways (enable only the ones you are actively developing)
ENABLE_NORMALIZATION_OXLINT_RAW=false
ENABLE_NORMALIZATION_OXLINT_JS_DEPS=false

# Future examples:
# ENABLE_NORMALIZATION_ESLINT=false
# ENABLE_NORMALIZATION_BIOME=false
# ENABLE_NORMALIZATION_PRETTIER=false

# DB location (overridden in prod by Helm + in dev script)
# DB_PATH=superset.db
